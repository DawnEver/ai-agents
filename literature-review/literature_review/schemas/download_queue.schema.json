{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:literature-review:download_queue",
  "title": "Literature Review Download Queue",
  "type": "object",
  "required": ["artifact_version", "screening_confirmation", "items"],
  "properties": {
    "artifact_version": {
      "$ref": "urn:literature-review:_common#/$defs/artifactVersion"
    },
    "screening_confirmation": {
      "allOf": [
        { "$ref": "urn:literature-review:_common#/$defs/approval" },
        {
          "required": ["screening_sha256"],
          "properties": {
            "screening_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          },
          "allOf": [
            {
              "if": { "properties": { "approved": { "const": true } }, "required": ["approved"] },
              "then": {
                "properties": {
                  "approved_at": { "type": "string", "format": "date-time" },
                  "approved_by": { "type": "string", "minLength": 1 }
                }
              }
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "provider", "download_priority", "approved"],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "provider": {
            "$ref": "urn:literature-review:_common#/$defs/provider"
          },
          "title": {
            "type": "string"
          },
          "publication_year": {
            "type": ["integer", "string"]
          },
          "publication_title": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          },
          "pdf_url": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          },
          "decision": {
            "type": "string",
            "enum": ["include", "maybe"]
          },
          "confidence": {
            "$ref": "urn:literature-review:_common#/$defs/confidence"
          },
          "inclusion_reasons": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "exclusion_reasons": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "uncertainties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "abstract_available": {
            "type": "boolean"
          },
          "download_priority": {
            "$ref": "urn:literature-review:_common#/$defs/downloadPriority"
          },
          "approved": {
            "type": "boolean"
          },
          "approval": {
            "type": "object",
            "required": ["approved_by", "approved_at"],
            "properties": {
              "approved_by": { "type": "string", "minLength": 1 },
              "approved_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": { "properties": { "approved": { "const": true } }, "required": ["approved"] },
            "then": { "required": ["approval"] },
            "else": { "not": { "required": ["approval"] } }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
