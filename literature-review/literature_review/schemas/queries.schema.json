{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:literature-review:queries",
  "title": "Literature Review Query Plan",
  "type": "object",
  "required": ["created_at", "constraints", "queries", "approval"],
  "properties": {
    "topic_id": { "type": "string" },
    "topic": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "brief_ref": {
      "type": "object",
      "required": ["research_scope_sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "research_scope_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "required": ["year_from", "year_to", "content_types"],
      "properties": {
        "year_from": { "type": "integer" },
        "year_to": { "type": "integer" },
        "content_types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "urn:literature-review:_common#/$defs/contentType" }
        },
        "preferred_venues": { "type": "array", "items": { "type": "string" } },
        "defaults_applied": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "open_access_only": { "type": "boolean" },
        "require_experimental_evidence": { "type": "boolean" },
        "exclude_reviews": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "concepts": {
      "type": "object",
      "oneOf": [
        {
          "required": ["selected_ids"],
          "properties": {
            "selected_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["groups"],
          "properties": {
            "groups": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "query_id",
          "purpose",
          "provider",
          "expression",
          "year_from",
          "year_to",
          "content_types",
          "sort",
          "enabled"
        ],
        "properties": {
          "query_id": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "provider": { "$ref": "urn:literature-review:_common#/$defs/provider" },
          "search_scope": { "type": "string", "enum": ["metadata", "abstract"] },
          "expression": { "type": "string", "minLength": 1 },
          "year_from": { "type": "integer" },
          "year_to": { "type": "integer" },
          "content_types": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "urn:literature-review:_common#/$defs/contentType" }
          },
          "sort": { "type": "string", "enum": ["relevance", "newest"] },
          "enabled": { "type": "boolean" },
          "concept_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "provenance": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "anyOf": [
          { "required": ["concept_ids"] },
          { "required": ["provenance"] }
        ],
        "additionalProperties": false
      }
    },
    "approval": {
      "allOf": [
        { "$ref": "urn:literature-review:_common#/$defs/approval" },
        {
          "properties": {
            "queries_sha256": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "allOf": [
            {
              "if": { "properties": { "approved": { "const": true } }, "required": ["approved"] },
              "then": {
                "properties": {
                  "approved_at": { "type": "string", "format": "date-time" },
                  "approved_by": { "type": "string", "minLength": 1 },
                  "queries_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                }
              }
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "anyOf": [
    { "required": ["topic_id", "topic", "concepts"] },
    { "required": ["brief_ref"] }
  ],
  "additionalProperties": false
}
