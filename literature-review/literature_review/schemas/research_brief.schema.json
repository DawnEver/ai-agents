{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:literature-review:research_brief",
  "title": "Literature Review Research Brief",
  "type": "object",
  "required": [
    "original_request",
    "research_objective",
    "constraints",
    "concepts",
    "approval"
  ],
  "properties": {
    "brief_id": { "type": "string", "minLength": 1 },
    "topic_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "$ref": "urn:literature-review:_common#/$defs/artifactVersion" },
    "created_at": { "type": "string", "format": "date-time" },
    "original_request": { "type": "string", "minLength": 1 },
    "research_objective": { "type": "string", "minLength": 1 },
    "inclusion_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "exclusion_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "criteria": {
      "type": "object",
      "required": ["include", "exclude"],
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "constraints": { "$ref": "#/$defs/constraints" },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/concept" }
    },
    "approval": {
      "allOf": [
        { "$ref": "urn:literature-review:_common#/$defs/approval" },
        {
          "properties": {
            "research_scope_sha256": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "allOf": [
            {
              "if": { "properties": { "approved": { "const": true } }, "required": ["approved"] },
              "then": {
                "properties": {
                  "approved_at": { "type": "string", "format": "date-time" },
                  "approved_by": { "type": "string", "minLength": 1 },
                  "research_scope_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                }
              }
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "$defs": {
    "constraints": {
      "type": "object",
      "required": ["year_from", "year_to", "content_types"],
      "properties": {
        "year_from": { "type": "integer", "minimum": 1900 },
        "year_to": { "type": "integer", "minimum": 1900 },
        "content_types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "urn:literature-review:_common#/$defs/contentType" },
          "uniqueItems": true
        },
        "preferred_venues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "defaults_applied": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "languages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "open_access_only": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "concept": {
      "type": "object",
      "required": ["concept_id", "role", "term", "synonyms", "rationale", "source", "selected"],
      "properties": {
        "concept_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "enum": ["must", "should", "context", "evidence", "exclude"] },
        "term": { "type": "string", "minLength": 1 },
        "synonyms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "rationale": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "selected": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["brief_id"] },
        { "required": ["topic_id"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["inclusion_criteria", "exclusion_criteria"] },
        { "required": ["criteria"] }
      ]
    },
    {
      "if": { "required": ["brief_id"] },
      "then": {
        "required": ["created_at", "inclusion_criteria", "exclusion_criteria"],
        "properties": {
          "constraints": {
            "required": ["preferred_venues", "defaults_applied"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
